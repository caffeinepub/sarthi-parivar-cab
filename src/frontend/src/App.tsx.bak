                        type="submit"
                        className="w-full bg-primary text-primary-foreground font-bold"
                        disabled={submitInquiry.isPending}
                        data-ocid="booking.submit_button"
                      >
                        {submitInquiry.isPending
                          ? "Submitting..."
                          : "Explore Cabs \u2192"}
