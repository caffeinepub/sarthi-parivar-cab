import {
  useGetAllInquiries,
  useGetContactMessages,
  useSubmitContact,
  useSubmitInquiry,
} from "@/hooks/useQueries";
import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
import {
  Car,
  CheckCircle,
  ChevronRight,
  Clock,
