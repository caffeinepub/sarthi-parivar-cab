                          className="pl-9"
                          value={roundTripForm.destination}
                          onChange={(e) =>
                            setRoundTripForm((p) => ({
                              ...p,
                              destination: e.target.value,
                            }))
                          }
                          required
                          data-ocid="booking.input"
                        />
                      </div>
                    </div>
                    <div className="space-y-1">
                      <Label
                        htmlFor="rt-date"
                        className="text-sm font-semibold"
                      >
                        Travel Date
                      </Label>
                      <Input
                        id="rt-date"
                        type="date"
