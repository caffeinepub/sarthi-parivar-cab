                        Number of Days
                      </Label>
                      <Input
                        id="rt-days"
                        type="number"
                        min="1"
                        placeholder="e.g. 3"
                        value={roundTripForm.days}
                        onChange={(e) =>
                          setRoundTripForm((p) => ({
                            ...p,
                            days: e.target.value,
                          }))
                        }
                        required
                        data-ocid="booking.input"
                      />
                    </div>
                    <div className="space-y-1">
                      <Label
                        htmlFor="rt-mobile"
                        className="text-sm font-semibold"
